# Copy to .env for local development (never commit .env)

PORT=5000
NODE_ENV=development

# MongoDB — local or MongoDB Atlas connection string
MONGO_URI=mongodb://127.0.0.1:27017/forever-yours

# Proposal data lifetime (hours)
PROPOSAL_TTL_HOURS=24
PROPOSAL_DRAFT_TTL_HOURS=72

# Local dev: leave empty OR list your dev URLs (localhost any port is allowed in development)
# Production (required): your live site URL, no trailing slash
# ALLOWED_ORIGINS=https://your-domain.com
